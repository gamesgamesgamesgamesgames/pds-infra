global:
  scrape_interval: 15s
  evaluation_interval: 15s

rule_files:
  - /etc/prometheus/alerts.yaml

alerting:
  alertmanagers:
    - static_configs:
        - targets:
            - localhost:{{ alertmanager_port }}

scrape_configs:
  - job_name: node
    static_configs:
      - targets:
          - localhost:{{ node_exporter_port }}
