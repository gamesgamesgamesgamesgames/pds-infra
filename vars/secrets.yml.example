# Copy this file to vars/secrets.yml and fill in the values.
# Then encrypt it: ansible-vault encrypt vars/secrets.yml --vault-password-file .vault-pass

# Grafana admin password
vault_grafana_admin_password: CHANGE_ME

# Discord webhook URL for Prometheus alerts
vault_discord_alert_webhook_url: https://discord.com/api/webhooks/CHANGE_ME

# PDS secrets (copy from /pds/pds.env on an existing server, or the installer generates them)
vault_pds_jwt_secret: CHANGE_ME
vault_pds_admin_password: CHANGE_ME
vault_pds_plc_rotation_key: CHANGE_ME

# S3-compatible blob storage (only needed if pds_blobstore_type is "s3")
# vault_pds_blobstore_s3_access_key: CHANGE_ME
# vault_pds_blobstore_s3_secret_key: CHANGE_ME
